{
  "manifest_version": 3,
  "name": "bLockIn",
  "version": "1.0",
  "description": "Plays a video when a certain web address is entered.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
